# Dependencies
__pycache__/
*.py[cod]
*$py.class
*.env
env/
venv/
ENV/
env.bak/
venv.bak/

# Data and Logs
data/
logs/
*.log

# Heavy debug/binary folders (Antigravity indexing optimization)
data/apks/
data/debug_captures/
data/scan_captures/
data/pet_releases/
data/workflow_logs/
backend/core/workflow/templates/_unknown_captures/

# Test and Debug folders
TEST/*
!TEST/game_state_reader/
!TEST/game_state_reader/**
TEST/game_state_reader/__pycache__/
TEST/game_state_reader/**/*.pyc
TEST/game_state_reader/artifacts/*
!TEST/game_state_reader/artifacts/.gitkeep
tests/
debug/
merge/

# Prevent test/debug files from being re-added under backend/core
backend/core/test_*.py
backend/core/debug_*/

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# User-specific configuration
api_keys.txt
config.json
*.local

# Project specific ignores
scan_captures/
RAW_SCREENS/
backend/core/workflow/templates/_unknown_captures/

# Cache
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Agent
.agent/
.agent_cache/
.codex/
